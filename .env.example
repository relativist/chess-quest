# Локальная разработка: npm run dev подключается к Postgres на localhost:5432
# с этими учётными данными автоматически (NODE_ENV=development).
# Переопределите при необходимости через .env или .env.local.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chess_quest"
# Production subpath deploys can set this, for example:
# NEXT_PUBLIC_BASE_PATH="/chess-quest"
